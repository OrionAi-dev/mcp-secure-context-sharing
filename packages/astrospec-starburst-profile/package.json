{
  "name": "@astrospec/starburst-profile",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Portable AstroSpec discovery and Starburst reasoning profile.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "schemas",
    "examples"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --shims",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "@astrospec/reasoning": "workspace:*",
    "@astrospec/runtime": "workspace:*",
    "@astrospec/schema": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "tsx": "^4.20.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
