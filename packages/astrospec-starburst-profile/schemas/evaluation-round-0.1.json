{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orionai-dev.github.io/AstroSpec/schemas/astrospec/starburst/evaluation-round-0.1.json",
  "title": "EvaluationRound",
  "type": "object",
  "additionalProperties": false,
  "required": ["roundId", "candidateIds", "scores"],
  "properties": {
    "roundId": { "type": "string", "minLength": 1 },
    "candidateIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "./evaluation-score-0.1.json" }
    },
    "skepticNotes": { "type": "array", "items": { "type": "string" } },
    "ext": { "type": "object", "additionalProperties": true }
  }
}
