{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orionai-dev.github.io/mcp-secure-context-sharing/schemas/astrospec/starburst/mutation-lineage-0.1.json",
  "title": "MutationLineage",
  "type": "object",
  "additionalProperties": false,
  "required": ["lineageId", "parentCandidateIds", "childCandidateId"],
  "properties": {
    "lineageId": { "type": "string", "minLength": 1 },
    "parentCandidateIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "childCandidateId": { "type": "string", "minLength": 1 },
    "mutationNotes": { "type": "array", "items": { "type": "string" } },
    "ext": { "type": "object", "additionalProperties": true }
  }
}
