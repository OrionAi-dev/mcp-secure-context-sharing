{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orionai-dev.github.io/mcp-secure-context-sharing/schemas/astrospec/starburst/analogical-mapping-0.1.json",
  "title": "AnalogicalMapping",
  "type": "object",
  "additionalProperties": false,
  "required": ["mappingId", "sourcePatternId", "targetProblem", "correspondences"],
  "properties": {
    "mappingId": { "type": "string", "minLength": 1 },
    "sourcePatternId": { "type": "string", "minLength": 1 },
    "targetProblem": { "type": "string", "minLength": 1 },
    "correspondences": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "./starburst-defs-0.1.json#/$defs/mappingCorrespondence" }
    },
    "mismatchNotes": { "type": "array", "items": { "type": "string" } },
    "structuralValidity": { "$ref": "./starburst-defs-0.1.json#/$defs/scoreDimension" },
    "ext": { "type": "object", "additionalProperties": true }
  }
}
