{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orionai-dev.github.io/AstroSpec/schemas/astrospec/graph-memory/structural-graph-query-0.1.json",
  "title": "StructuralGraphQuery",
  "type": "object",
  "additionalProperties": false,
  "required": ["abstractionFingerprint"],
  "properties": {
    "queryId": { "type": "string" },
    "abstractionFingerprint": { "type": "string", "minLength": 1 },
    "mechanismTags": { "type": "array", "items": { "type": "string" } },
    "topologySignature": { "type": "string" },
    "constraintVector": { "type": "array", "items": { "type": "string" } },
    "relationMotifs": {
      "type": "array",
      "items": { "$ref": "./graph-memory-defs-0.1.json#/$defs/relationshipType" }
    },
    "domainHints": { "type": "array", "items": { "type": "string" } },
    "maxDepth": { "type": "integer", "minimum": 0 },
    "topK": { "type": "integer", "minimum": 1 },
    "ext": { "type": "object", "additionalProperties": true }
  }
}
