{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@mcp-secure-context/core": ["packages/mcp-secure-context-core/src/index.ts"],
      "@mcp-secure-context/extensions-astrospec": ["packages/mcp-secure-context-extensions-astrospec/src/index.ts"],
      "@mcp-secure-context/openspec": ["packages/mcp-secure-context-openspec/src/index.ts"],
      "@mcp-secure-context/mcp-adapter": ["packages/mcp-secure-context-mcp-adapter/src/index.ts"],
      "@mcp-secure-context/sdk-typescript": ["packages/mcp-secure-context-sdk-typescript/src/index.ts"],
      "@mcp-secure-context/cli": ["packages/mcp-secure-context-cli/src/cli.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "**/dist/**"
  ]
}
